<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <!-- Test execution settings -->
  <RunConfiguration>
    <!-- Maximum timeout for test run (in milliseconds) -->
    <TestSessionTimeout>300000</TestSessionTimeout>
    <!-- Run tests sequentially to avoid static state issues -->
    <MaxCpuCount>1</MaxCpuCount>
  </RunConfiguration>

  <!-- xUnit adapter settings -->
  <xUnit>
    <!-- Timeout for individual test (in milliseconds) -->
    <MaxParallelThreads>1</MaxParallelThreads>
  </xUnit>
</RunSettings>
